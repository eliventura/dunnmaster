generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────

enum DeclineType {
  SOFT
  HARD
}

enum RecoveryCaseStatus {
  PENDING
  RETRYING
  EMAILING
  RECOVERED
  FAILED
  CANCELLED
  PAUSED
}

enum RecoveryPhase {
  RETRY
  EMAIL
  COMPLETE
}

enum RetryStatus {
  SCHEDULED
  EXECUTING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum EmailTemplateType {
  FRIENDLY_NOTICE
  URGENCY
  FINAL_WARNING
}

enum EmailStatus {
  SCHEDULED
  SENT
  CANCELLED
  FAILED
}

enum SessionStatus {
  ACTIVE
  USED
  EXPIRED
}

enum PlanTier {
  STARTER
  GROWTH
  SCALE
}

enum PlanStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
}

// ── NextAuth Models ────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  business Business?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Business Models ────────────────────────────────────

model Business {
  id                  String    @id @default(cuid())
  userId              String    @unique
  stripeAccountId     String?   @unique
  stripeAccessToken   String?
  stripeRefreshToken  String?
  stripeConnectedAt   DateTime?
  monitoringActive    Boolean   @default(false)
  timezone            String    @default("UTC")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandingSettings BrandingSettings?
  subscriptionPlan SubscriptionPlan?
  recoveryCases    RecoveryCase[]
}

model BrandingSettings {
  id           String  @id @default(cuid())
  businessId   String  @unique
  companyName  String
  logoUrl      String?
  primaryColor String  @default("#6366f1")
  accentColor  String  @default("#4f46e5")
  supportEmail String?
  customDomain String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model SubscriptionPlan {
  id                   String     @id @default(cuid())
  businessId           String     @unique
  tier                 PlanTier   @default(STARTER)
  stripeSubscriptionId String?    @unique
  stripePriceId        String
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  mrrLimit             Int
  currentMrrMonitored  Int        @default(0)
  status               PlanStatus @default(ACTIVE)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// ── Recovery Models ────────────────────────────────────

model RecoveryCase {
  id                   String             @id @default(cuid())
  businessId           String
  stripeInvoiceId      String
  stripeCustomerId     String
  stripeSubscriptionId String
  customerEmail        String
  customerTimezone     String             @default("UTC")
  amountDue            Int
  currency             String             @default("usd")
  declineCode          String
  declineType          DeclineType
  status               RecoveryCaseStatus @default(PENDING)
  phase                RecoveryPhase      @default(RETRY)
  recoveredAt          DateTime?
  failedAt             DateTime?
  expiresAt            DateTime
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  business              Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  retryAttempts         RetryAttempt[]
  dunningEmails         DunningEmail[]
  paymentUpdateSessions PaymentUpdateSession[]

  @@unique([businessId, stripeInvoiceId])
  @@index([businessId, status])
  @@index([expiresAt, status])
}

model RetryAttempt {
  id                   String      @id @default(cuid())
  recoveryCaseId       String
  attemptNumber        Int
  scheduledAt          DateTime
  executedAt           DateTime?
  status               RetryStatus @default(SCHEDULED)
  stripePaymentIntentId String?
  failureCode          String?
  failureMessage       String?
  inngestEventId       String?
  createdAt            DateTime    @default(now())

  recoveryCase RecoveryCase @relation(fields: [recoveryCaseId], references: [id], onDelete: Cascade)

  @@unique([recoveryCaseId, attemptNumber])
  @@index([scheduledAt, status])
}

model DunningEmail {
  id              String            @id @default(cuid())
  recoveryCaseId  String
  sequenceNumber  Int
  templateType    EmailTemplateType
  resendEmailId   String?
  scheduledAt     DateTime
  sentAt          DateTime?
  status          EmailStatus       @default(SCHEDULED)
  subject         String
  toEmail         String
  createdAt       DateTime          @default(now())

  recoveryCase RecoveryCase @relation(fields: [recoveryCaseId], references: [id], onDelete: Cascade)

  @@unique([recoveryCaseId, sequenceNumber])
  @@index([scheduledAt, status])
}

model PaymentUpdateSession {
  id                 String        @id @default(cuid())
  recoveryCaseId     String
  token              String        @unique
  stripeSetupIntentId String?
  expiresAt          DateTime
  usedAt             DateTime?
  status             SessionStatus @default(ACTIVE)
  createdAt          DateTime      @default(now())

  recoveryCase RecoveryCase @relation(fields: [recoveryCaseId], references: [id], onDelete: Cascade)
}

// ── Webhook Idempotency ────────────────────────────────

model WebhookEvent {
  id              String   @id @default(cuid())
  stripeEventId   String   @unique
  eventType       String
  stripeAccountId String
  processedAt     DateTime @default(now())
  payload         Json?
}
